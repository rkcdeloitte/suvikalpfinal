rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // One profile doc per user, keyed by their auth uid.
    match /users/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /testimonials/{testimonialId} {
      // Public (and signed-out visitors) can read only approved testimonials.
      // The owner can read their own regardless of status. Admin can read all.
      allow read: if resource.data.status == 'approved'
                  || (request.auth != null && request.auth.uid == resource.data.uid)
                  || (request.auth != null && request.auth.token.email in ['rkcdeloitte@gmail.com']);

      // Any signed-in user can submit a testimonial, but it must be tied to
      // their own uid and always created as 'pending' — no self-approval.
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == 'pending';

      // Only the admin can change status (approve/reject).
      allow update: if request.auth != null
                    && request.auth.token.email in ['rkcdeloitte@gmail.com'];

      // The admin can delete any testimonial. The owner can withdraw their own
      // — but only while it's still pending, so they can't erase an approved
      // or rejected decision after the fact.
      allow delete: if request.auth != null
                    && (request.auth.token.email in ['rkcdeloitte@gmail.com']
                        || (request.auth.uid == resource.data.uid && resource.data.status == 'pending'));
    }
  }
}

// Paste this whole file into Firebase Console → Firestore Database → Rules tab,
// then click Publish.
